@using Rsp.Portal.Application.Constants
@using Rsp.Portal.Application.DTOs.Responses.CmsContent
@model AreaOfChangeViewModel
@{
    ViewBag.Title = (string?)ViewData[PageContentElements.MetaTitle];
    var pageContentData = (Dictionary<string, MixedContentPageItem?>?)ViewData[PageContentElements.PageContent];
    var pageContent = pageContentData != null
        ? pageContentData
        : new Dictionary<string, MixedContentPageItem?>();

    Model.ModificationIdentifier = TempData[TempDataKeys.ProjectModification.ProjectModificationIdentifier] as string;
    TempData.Keep(TempDataKeys.ProjectModification.ProjectModificationIdentifier);
    var title = pageContent.GetValueOrDefault("Modifications.ConfirmModificationJourney.ProjectRestartWarningTitle", null);
    var body = pageContent.GetValueOrDefault("Modifications.ConfirmModificationJourney.ProjectRestartWarningContent", null);
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">@Html.Raw(title?.Value)</h1>
        <partial name="_ProjectModificationSummary" model="Model" view-data="ViewData" />
        <p class="govuk-body">
            @Html.Raw(body?.Value)
        </p>
        <div class="save-buttons">
            <a class="govuk-button" asp-route="pmc:areaofchange" asp-route-projectModificationId="@Model.ModificationId" asp-route-projectRecordId="@Model.ProjectRecordId">
                Return to select area of change
            </a>
        </div>
    </div>
</div>