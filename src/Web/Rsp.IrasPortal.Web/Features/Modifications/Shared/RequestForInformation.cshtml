@using Rsp.Portal.Domain.Identity
@using Rsp.Portal.Web.Features.Modifications.Models
@using Rsp.Portal.Application.Constants
@model ModificationDetailsViewModel

<h2 class="govuk-heading-m">Request for further information</h2>
@for (var i = 0; i < Model.RfiModel.RfiReasons.Count; i++)
{
    var rfiResponse = Model.RfiModel.RfiResponses.ElementAtOrDefault(i);

    var initialResponse = rfiResponse?
        .InitialResponse?
        .FirstOrDefault();

    var reviseAndAuthorise = rfiResponse?
        .ReviseAndAuthorise?
        .FirstOrDefault();

    var reasonForReviseAndAuthorise = rfiResponse?
        .ReasonForReviseAndAuthorise?
        .FirstOrDefault();

    var sponsorRequestRevisionResponse = rfiResponse?
        .RequestRevisionsBySponsor?
        .FirstOrDefault();

    var applicantRequestRevisionResponse = rfiResponse?
        .RequestRevisionsByApplicant?
        .FirstOrDefault();

    var shouldDisplayResponse = (!string.IsNullOrWhiteSpace(initialResponse)
        || !string.IsNullOrWhiteSpace(reviseAndAuthorise)
        || !string.IsNullOrWhiteSpace(reasonForReviseAndAuthorise)
        || !string.IsNullOrWhiteSpace(sponsorRequestRevisionResponse)
        || !string.IsNullOrWhiteSpace(applicantRequestRevisionResponse))
        && (Model.Status != ModificationStatus.RequestForInformation || User.IsInRole(Roles.Applicant));

    <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title">
                Request for further information @(shouldDisplayResponse ? "and response" : "")
            </h2>
        </div>
        <div class="govuk-summary-card__content">
            <div class="govuk-summary-card__content">
                <dl class="govuk-summary-list">
                    <div class="govuk-summary-list__row">
                        <dt class="govuk-summary-list__key">
                            Reason @(i + 1)
                        </dt>
                        <dd class="govuk-summary-list__value">
                            @Model.RfiModel.RfiReasons[i]
                        </dd>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(reasonForReviseAndAuthorise) && Model.RfiModel.IsLastSponsorReasonForReviseAndAuthoriseDraft is false)
                    {
                        <!-- REVISED RESPONSE -->
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">
                                Response to reason @(i + 1)
                            </dt>
                            <dd class="govuk-summary-list__value">
                                @reviseAndAuthorise
                            </dd>
                        </div>

                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">
                                Reason for revised response to reason @(i + 1)
                            </dt>
                            <dd class="govuk-summary-list__value">
                                @reasonForReviseAndAuthorise
                            </dd>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(sponsorRequestRevisionResponse) && Model.RfiModel.IsLastSponsorRequestRevisionsDraft is false)
                    {
                        <!-- REQUEST REVISIONS - DURING APPLICANTS REVISION -->
                        if (Model.Status is ModificationStatus.ResponseRequestRevisions)
                        {  
                            <div class="govuk-summary-list__row">
                                <dt class="govuk-summary-list__key">
                                    Response to reason @(i + 1)
                                </dt>
                                <dd class="govuk-summary-list__value">
                                    @(string.IsNullOrWhiteSpace(initialResponse)
                                            ? "No response provided"
                                            : initialResponse)
                                </dd>
                            </div>

                            <div class="govuk-summary-list__row">
                                <dt class="govuk-summary-list__key">
                                    Requested revisions to response to reason @(i + 1)
                                </dt>
                                <dd class="govuk-summary-list__value">
                                    @sponsorRequestRevisionResponse
                                </dd>
                            </div>                        
                        }
                        else
                        {                
                            <!-- REQUEST REVISIONS - AFTER APPLICANTS REVISION SENT TO SPONSOR -->
                            <div class="govuk-summary-list__row">
                                <dt class="govuk-summary-list__key">
                                    Requested revisions to response to reason @(i + 1)
                                </dt>
                                <dd class="govuk-summary-list__value">
                                    @sponsorRequestRevisionResponse
                                </dd>
                            </div>

                            <div class="govuk-summary-list__row">
                                <dt class="govuk-summary-list__key">
                                    Updated response to reason @(i + 1)
                                </dt>
                                <dd class="govuk-summary-list__value">
                                    @(string.IsNullOrWhiteSpace(applicantRequestRevisionResponse)
                                            ? "No response provided"
                                            : applicantRequestRevisionResponse)
                                </dd>
                            </div>                        
                        }
                    }
                    else
                    {
                        <!-- INITIAL RESPONSE (DEFAULT) -->
                        if (shouldDisplayResponse)
                        {
                            <div class="govuk-summary-list__row">
                                <dt class="govuk-summary-list__key">
                                    Response to reason @(i + 1)
                                </dt>
                                <dd class="govuk-summary-list__value">
                                    @initialResponse
                                </dd>
                            </div>
                        }
                    }
                </dl>
            </div>
        </div>
    </div>
}