@using System.Globalization
@using System.Text.Json
@using Microsoft.AspNetCore.Mvc.ModelBinding
@using Microsoft.FeatureManagement
@using Rsp.Portal.Application.Constants
@using Rsp.Portal.Web.Features.Modifications.Models
@model BaseProjectModificationViewModel

@{
    //string projectRecordId, string irasId, string shortTitle, Guid projectModificationId

    var modificationParams = new Dictionary<string, string> {
            { "projectRecordId", Model.ProjectRecordId },
            { "irasId", Model.IrasId  },
            { "shortTitle", Model.ShortTitle ?? string.Empty },
            { "projectModificationId", Model.ModificationId ?? string.Empty },
            { "sponsorOrganisationUserId", Model.SponsorOrganisationUserId ?? string.Empty },
            { "rtsId", Model.RtsId ?? string.Empty }
        };

    var saveButtonTitle = Model.Status switch
    {
        ModificationStatus.RequestRevisions or ModificationStatus.ResponseRequestRevisions => "Return to make revision",
        ModificationStatus.ReviseAndAuthorise => "Return to revise and authorise",
        _ => "Return to modification details"
    };
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-l">Your modification needs to contain at least one change</h1>
        <partial name="_ProjectModificationSummary" model="Model" view-data="ViewData" />

        <p class="govuk-body" status-for="Status"
           status-is="@ModificationStatus.ReviseAndAuthorise">
            You can't authorise this modification until you've added at least one change. Return to the modification details page where you can add a change.
        </p>

        <p class="govuk-body"
           status-for="Status"
           status-is="@ModificationStatus.ReviseAndAuthorise"
           status-mode="Hide">
            You can't send this modification to sponsor for review until you've added at least one change. Return to the modification details page where you can add a change.
        </p>

        <div class="save-buttons">
            <a class="govuk-button"
               asp-route="pmc:modificationdetails"
               asp-all-route-data="modificationParams">
                @saveButtonTitle
            </a>
        </div>
    </div>
</div>