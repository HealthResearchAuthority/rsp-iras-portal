@using Microsoft.FeatureManagement
@using Rsp.Portal.Application.Constants
@using Rsp.Portal.Application.DTOs
@using Rsp.Portal.Application.DTOs.Responses.CmsContent
@using Rsp.Portal.Web.Features.Modifications.Models
@using Rsp.Portal.Web.Helpers
@model ModificationDetailsViewModel
@inject IFeatureManager featureManager


@{
    bool isRevisionBySponsor = ViewBag.IsRevisionBySponsor as bool? ?? false;
    var pageContentData = (Dictionary<string, MixedContentPageItem?>?)ViewData[PageContentElements.PageContent];
    var pageContent = pageContentData != null ?
        pageContentData :
        new Dictionary<string, MixedContentPageItem?>();

    var description = pageContent.GetValueOrDefault("Modifications.Documents.SupportingDocuments.Description", null);

    var path = Context.Request.Path.Value?.ToLower() ?? "";

    var downloadSource =
        path.Contains("modifications/reviewallchanges")
            ? "ReviewAllChanges"
            : path.Contains("modifications/modificationdetails")
                ? "ModificationDetails"
                : "";
}
<script>
    document.documentElement.classList.add("js-enabled");
</script>
<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <h2 class="govuk-heading-m">Supporting documents</h2>
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-full">
                <div class="govuk-table-wrapper">
                    <form method="get" id="projectdocuments-selection">
                        @Html.AntiForgeryToken()
                        <div id="supporting-documents-description-label">
                            @Html.Raw(description?.Value)
                        </div>
                        <table class="govuk-table" id="projectDocumentsTable">
                            <thead class="govuk-table__head">
                                <tr>
                                    <th class="govuk-table__header" colspan="8">
                                        <feature name="@FeatureFlags.DocumentsSelectiveDownload">
                                            @if (Model.ProjectOverviewDocumentViewModel?.Documents.Count() > 0)
                                            {
                                                <div id="selectAllContainer"
                                                     class="govuk-checkboxes govuk-checkboxes--small table-checkbox">

                                                    <div class="govuk-checkboxes__item">
                                                        <input class="govuk-checkboxes__input"
                                                               type="checkbox"
                                                               id="selectAllCheckbox" />

                                                        <label class="govuk-label govuk-checkboxes__label"
                                                               for="selectAllCheckbox">
                                                            Select all documents on this page
                                                        </label>
                                                    </div>

                                                </div>
                                            }
                                        </feature>
                                    </th>
                                </tr>
                                <tr class="govuk-table__row govuk-table__header-sortable govuk-body-s">
                                    <feature name="@FeatureFlags.DocumentsSelectiveDownload">
                                        <th class="govuk-table__header">Select</th>
                                    </feature>
                                    @{
                                        var sortableHeaders = new[]
                                        {
                                                                        new { Field = nameof(ProjectOverviewDocumentDto.DocumentType), Label = "Document type" },
                                                                        new { Field = nameof(ProjectOverviewDocumentDto.DocumentName), Label = "Document name" },
                                                                        new { Field = nameof(ProjectOverviewDocumentDto.FileName), Label = "File name" },
                                                                        new { Field = nameof(ProjectOverviewDocumentDto.DocumentVersion), Label = "Version" },
                                                                        new { Field = nameof(ProjectOverviewDocumentDto.DocumentDate), Label = "Document date" }
                                                                        };
                                    }

                                    @foreach (var header in sortableHeaders)
                                    {
                                        var displayText = header.Label.Contains(" ")
                                        ? header.Label.Replace(" ", "<br />")
                                        : header.Label;

                                        <th scope="col" class="govuk-table__header govuk-table__header-sortable">
                                            @await Html.PartialAsync("_SortableHeaderButton", new SortableHeaderModel
                                            {
                                                FieldName = header.Field,
                                                                                DisplayText = displayText,
                                                                                CurrentSortField = Model.ProjectOverviewDocumentViewModel.Pagination?.SortField,
                                                                                CurrentSortDirection = Model.ProjectOverviewDocumentViewModel.Pagination?.SortDirection,
                                                                                AdditionalParameters = new Dictionary<string, string>
                                                                                {
                                                                                { "projectRecordId", Model.ProjectRecordId },
                                                                                { "irasId", Model.IrasId },
                                                                                { "shortTitle", Model.ShortTitle! },
                                                                                { "projectModificationId", Model.ModificationId },
                                                                                { "documents", ModificationOverview.Documents }
                                                                                }
                                                                                })
                                    </th>
                                                                        }
                                    <th scope="col" class="govuk-table__header">Status</th>
                                    @if (Model.Status is ModificationStatus.InDraft || (isRevisionBySponsor && Model.Status is ModificationStatus.ReviseAndAuthorise))
                                    {
                                        <th scope="col" class="govuk-table__header">Action</th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="govuk-table__body govuk-body-s">
                                @foreach (var modification in Model.ProjectOverviewDocumentViewModel?.Documents ?? Enumerable.Empty<ProjectOverviewDocumentDto>())
                                {
                                    var isFailed = string.Equals(modification.Status, DocumentStatus.Failed, StringComparison.OrdinalIgnoreCase);
                                    var isTracked = string.Equals(modification.SupersedeDocumentType, SupersedeDocumentsType.Tracked.ToString(), StringComparison.OrdinalIgnoreCase);
                                    var isScanInProgress = modification.IsMalwareScanSuccessful == null;

                                    var rowClass = isFailed ? "scan-failed" : isScanInProgress ? "scan-pending" : "";
                                    var trClass = "govuk-table__row";
                                    var rowSpan = 1;
                                    if (await featureManager.IsEnabledAsync(FeatureFlags.DocumentsMalware))
                                    {
                                        trClass += $" document-row {rowClass}";
                                        rowSpan = (isFailed || isScanInProgress) ? 2 : 1;
                                    }

                                    <tr class="@trClass">
                                        <feature name="@FeatureFlags.DocumentsSelectiveDownload">
                                            <td class="govuk-table__cell checkbox-cell"
                                                rowspan="@rowSpan">
                                                <div class="govuk-checkboxes govuk-checkboxes--small table-checkbox">
                                                    <div class="govuk-checkboxes__item">
                                                        <input type="checkbox"
                                                               id="@modification.Id"
                                                               name="SelectedDocuments"
                                                               value="@modification.DocumentStoragePath"
                                                               form="download-selection-form"
                                                               aria-label="Select record @modification.Id"
                                                               class="govuk-checkboxes__input document-checkbox" />
                                                        <label for="@modification.Id"
                                                               class="govuk-label govuk-checkboxes__label"></label>
                                                    </div>
                                                </div>
                                            </td>
                                        </feature>
                                        <td class="govuk-table__cell">
                                            <span class="govuk-!-font-weight-bold">@modification.DocumentType</span>
                                        </td>
                                        <td class="govuk-table__cell">@modification.DocumentName</td>
                                        <td class="govuk-table__cell">
                                            @if (modification.IsMalwareScanSuccessful == true)
                                            {
                                                <a asp-route="pmc:downloaddocument"
                                                   asp-route-fileName="@modification.FileName"
                                                   asp-route-path="@modification.DocumentStoragePath"
                                                   class="govuk-link">
                                                    @modification.FileName
                                                </a>
                                            }
                                            else
                                            {
                                                @modification.FileName
                                            }
                                        </td>
                                        <td class="govuk-table__cell">@modification.DocumentVersion</td>
                                        <td class="govuk-table__cell">@modification.DocumentDate?.ToString("d MMM yyyy")</td>
                                        <td class="govuk-table__cell">
                                            @{
                                                var tagClass = modification.Status switch
                                                {
                                                    DocumentStatus.Failed => "govuk-tag--red",
                                                    DocumentStatus.Incomplete => "govuk-tag--blue",
                                                    DocumentStatus.Complete => "govuk-tag--blue",
                                                    ModificationStatus.WithSponsor => "govuk-tag--yellow",
                                                    ModificationStatus.ReviseAndAuthorise => "govuk-tag--yellow",
                                                    ModificationStatus.Approved => "govuk-tag--green",
                                                    ModificationStatus.WithReviewBody => "govuk-tag--green",
                                                    ModificationStatus.NotApproved => "govuk-tag--red",
                                                    ModificationStatus.NotAuthorised => "govuk-tag--red",
                                                    ModificationStatus.Withdrawn => "govuk-tag--red",
                                                    _ => "govuk-tag--blue"
                                                };
                                            }
                                            <strong class="govuk-tag @(tagClass)">
                                                @ModificationStatusHelper.ToUiStatus(modification.Status)
                                            </strong>
                                        </td>
                                        @if (
                                            Model.Status is ModificationStatus.InDraft
                                            || Model.Status is ModificationStatus.RequestRevisions
                                            || (isRevisionBySponsor && Model.Status is ModificationStatus.ReviseAndAuthorise)
                                        )
                                        {
                                            <td class="govuk-table__cell">
                                                @if (!isFailed && !isTracked)
                                                {
                                                    <a asp-route="pmc:continuetodetails"
                                                       asp-route-documentId="@modification.Id"
                                                       asp-route-reviewAllChanges="true"
                                                       class="govuk-link">
                                                        Change details
                                                    </a>
                                                }
                                            </td>
                                        }
                                        @if (isRevisionBySponsor && Model.Status is ModificationStatus.ReviseAndAuthorise)
                                        {
                                            <td class="govuk-table__cell">
                                                @if (!isFailed && !isTracked)
                                                {
                                                    <a asp-route="pmc:continuetodetails"
                                                       asp-route-documentId="@modification.Id"
                                                       asp-route-reviewAllChanges="false"
                                                       class="govuk-link">
                                                        Change details
                                                    </a>
                                                }
                                            </td>
                                        }
                                    </tr>
                                    <feature name="@FeatureFlags.DocumentsMalware">
                                        @if (isScanInProgress || isFailed)
                                        {
                                            <tr class="govuk-table__row document-row document-row-message @rowClass">

                                                <td colspan="8" class="govuk-table__cell">

                                                    @if (isScanInProgress)
                                                    {
                                                        <strong>This document is being scanned</strong>
                                                    }

                                                    @if (isFailed)
                                                    {
                                                        <p class="govuk-error-message govuk-!-margin-bottom-2">
                                                            The selected file contains a virus
                                                        </p>

                                                        <form asp-route="pmc:confirmdeletedocument"
                                                              asp-route-id="@modification.Id"
                                                              asp-route-backRoute="toaddpage"
                                                              method="get"
                                                              class="govuk-!-margin-bottom-0">
                                                            <input type="hidden" name="id" value="@modification.Id" />
                                                            <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0">
                                                                Delete
                                                            </button>
                                                        </form>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </feature>
                                }
                            </tbody>
                        </table>
                    </form>
                </div>
                <partial name="_Pagination" model="@Model.ProjectOverviewDocumentViewModel?.Pagination" />
            </div>
        </div>
    </div>
</div>

<div status-for="Status" status-is="@ModificationStatus.InDraft" class="govuk-button-group">
    <form method="get">
        @{
            ViewBag.Style = "govuk-button govuk-button--secondary";
        }
        <partial name="_SubmitButton" model="@("pmc:projectdocument", "Add documents", new Dictionary<string, string> { })" />
    </form>
</div>

<div status-for="Status" status-is="@ModificationStatus.ReviseAndAuthorise" class="govuk-button-group">
    @if (isRevisionBySponsor)
    {
        <form method="get">
            @{
                ViewBag.Style = "govuk-button govuk-button--secondary";
            }
            <partial name="_SubmitButton" model="@("pmc:projectdocument", "Add documents", new Dictionary<string, string> { })" />
        </form>
    }
</div>

<p class="govuk-body">
    Select 'Download all' to save all documents to a zip file.
    <br />

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <a asp-route="pmc:downloaddocumentsaszip"
               asp-route-folderName="@Model.ModificationId"
               class="govuk-button govuk-button--secondary">
                Download all
            </a>
        </div>
    </div>
</p>
<feature name="@FeatureFlags.DocumentsSelectiveDownload">
    @if (Model.ProjectOverviewDocumentViewModel?.Documents.Count() > 0)
    {
        <div id="selectionPanel"
             class="govuk-!-margin-top-4 govuk-!-padding-4"
             style="border:1px solid #b1b4b6;">

            <p class="govuk-body govuk-!-margin-bottom-2">

                <!-- Shown ONLY when JS is disabled -->
                <noscript>
                    <strong>Apply action to selected items</strong>
                </noscript>

                <!-- Hidden by default -->
                <span id="jsSelectionText" class="govuk-!-display-none">
                    <strong>
                        <span id="selectedCount">0</span>
                        documents selected for download on this page
                    </strong>
                </span>
            </p>

            <div class="govuk-button-group">
                <form method="get" asp-route="pmc:downloaddocumentsselectionaszip" id="download-selection-form">
                    <input type="hidden" id="downloadSource" name="downloadSource" value="@downloadSource" />
                    <button type="submit" id="DownloadSelectionButton" class="govuk-button govuk-button--secondary">
                        Download selection
                    </button>
                </form>

                <a id="clearSelection" class="govuk-link" href="#">
                    Clear selection
                </a>
            </div>
        </div>
    }
</feature>
<br />
<style>
    .js-enabled #selectionPanel {
        display: none;
    }
</style>
<script>
    document.addEventListener("change", function (e) {

        // Individual document checkbox
        if (e.target.classList.contains("document-checkbox")) {
            updateSelectionUI();
        }

        // Select all checkbox
        if (e.target.id === "selectAllCheckbox") {

            const table = document.getElementById("projectDocumentsTable");
            if (!table) return;

            const checkboxes = table.querySelectorAll(".document-checkbox");

            checkboxes.forEach(cb => {
                cb.checked = e.target.checked;
            });

            updateSelectionUI();
        }
    });

    document.addEventListener("click", function (e) {

        // Clear selection
        if (e.target.id === "clearSelection") {

            e.preventDefault();

            const table = document.getElementById("projectDocumentsTable");
            if (!table) return;

            const checkboxes = table.querySelectorAll(".document-checkbox");
            const selectAll = document.getElementById("selectAllCheckbox");

            checkboxes.forEach(cb => cb.checked = false);

            if (selectAll) {
                selectAll.checked = false;
            }

            updateSelectionUI();
        }
    });

    function updateSelectionUI() {

        const table = document.getElementById("projectDocumentsTable");
        if (!table) return;

        const jsSelectionText = document.getElementById("jsSelectionText");
        if (jsSelectionText) {
            jsSelectionText.classList.remove("govuk-!-display-none");
        }

        const selectAllContainer = document.getElementById("selectAllContainer");
        if (selectAllContainer) {
            selectAllContainer.classList.remove("govuk-!-display-none");
        }

        const selectionPanel = document.getElementById("selectionPanel");
        const selectedCountText = document.getElementById("selectedCount");
        const selectAll = document.getElementById("selectAllCheckbox");

        const checkboxes = table.querySelectorAll(".document-checkbox");

        let selectedCount = 0;

        checkboxes.forEach(cb => {

            const row = cb.closest(".document-row");
            const messageRow = row?.nextElementSibling?.classList.contains("document-row-message")
                ? row.nextElementSibling
                : null;

            if (cb.checked) {

                selectedCount++;

                row?.classList.add("selected");
                messageRow?.classList.add("selected");

            } else {

                row?.classList.remove("selected");
                messageRow?.classList.remove("selected");

            }

        });

        if (selectedCountText) {
            selectedCountText.textContent = selectedCount;
        }

        // show/hide selection panel
        if (selectionPanel) {
            selectionPanel.style.display = selectedCount > 0 ? "block" : "none";
        }

        // update select all state
        if (selectAll) {
            selectAll.checked = selectedCount === checkboxes.length && checkboxes.length > 0;
        }
    }

    document.addEventListener("DOMContentLoaded", function () {

        const jsSelectionText = document.getElementById("jsSelectionText");
        if (jsSelectionText) {
            jsSelectionText.classList.remove("govuk-!-display-none");
        }

        const selectAllContainer = document.getElementById("selectAllContainer");
        if (selectAllContainer) {
            selectAllContainer.classList.remove("govuk-!-display-none");
        }

        updateSelectionUI();
    });
</script>