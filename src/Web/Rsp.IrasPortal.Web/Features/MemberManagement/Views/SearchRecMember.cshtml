@using Rsp.IrasPortal.Web.Features.MemberManagement.Models
@using Rsp.Portal.Application.Constants
@using Rsp.Portal.Application.DTOs.Responses.CmsContent
@model AddRecMemberViewModel

@{
	ViewBag.Title = (string?)ViewData[PageContentElements.MetaTitle];

	var pageContentData = (Dictionary<string, MixedContentPageItem?>?)ViewData[PageContentElements.PageContent];
	var pageContent = pageContentData != null
		? pageContentData
		: new Dictionary<string, MixedContentPageItem?>();

	var headline = pageContent.GetValueOrDefault("MemberManagement.AddMember.SearchMember.Title", null);
	var body = pageContent.GetValueOrDefault("MemberManagement.AddMember.SearchMember.Body", null);
}

@section BackNavigation {
	<partial name="_BackNavigation" model="@("TODO", "Back", new Dictionary<string, string> { { "RecId", Model.RecId.ToString() } })" />
}

<div class="govuk-grid-row">
	<div class="govuk-grid-column-two-thirds">

		<partial name="_ValidationSummary" model="@(ViewData.ModelState, "There is a problem")" />
		<div class="govuk-caption-l">
			@Model.RecName
		</div>
		<h1 class="govuk-heading-l">@Html.Raw(headline?.Value)</h1>
	</div>
</div>

<div class="govuk-grid-row">
	<div class="govuk-grid-column-two-thirds">
		<form method="post" class="govuk-form-group">

			<p>
				@Html.Raw(body?.Value)
			</p>
			<br />
			<div class="govuk-form-group">

				<label class="govuk-label" for="Email">
					<b>Find a research ethics committee member</b>
				</label>

				<p class="govuk-hint">Search using the email address</p>

				<div class="search-flex-container">
					<input type="email" class="govuk-input" asp-for="Email" />

					@{
						ViewBag.Style = "govuk-button govuk-button--secondary";
					}
					<partial name="_SubmitButton"
							 model="@("mm:SearchRecMember", "Search", new Dictionary<string, string>())" />
				</div>

			</div>

			<input type="hidden" readonly name="RecId" value="@Model.RecId" />
			<input type="hidden" readonly name="RecName" value="@Model.RecName" />

			<br />
		</form>
	</div>

	@if (Model.Users != null && Model.Users.Any())
	{
		<div class="govuk-grid-column-full">
			<table class="govuk-table">
				<thead class="govuk-table__head">
					<tr class="govuk-table__row govuk-table__header-sortable">
						<th class="govuk-table__header govuk-table__header-sortable">First name</th>
						<th class="govuk-table__header govuk-table__header-sortable">Last name</th>
						<th class="govuk-table__header govuk-table__header-sortable">Email</th>
						<th class="govuk-table__header">Action</th>
					</tr>
				</thead>
				<tbody class="govuk-table__body">
					@foreach (var user in Model.Users)
					{
						<tr class="govuk-table__row">
							<td class="govuk-table__cell">@user.GivenName</td>
							<td class="govuk-table__cell">@user.FamilyName</td>
							<td class="govuk-table__cell">@user.Email</td>
							<td class="govuk-table__cell">
								<a class="govuk-link"
								   asp-route="mm:AddRecMember"
								   asp-route-recId="@Model.RecId"
								   asp-route-userId="@user.Id">
									Add member
								</a>

							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}

</div>

