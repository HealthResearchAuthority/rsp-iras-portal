@using Rsp.IrasPortal.Web.Features.MemberManagement.Models
@using Rsp.Portal.Application.Constants
@using Rsp.Portal.Application.DTOs.Responses.CmsContent
@model string;

@{
	ViewBag.Title = (string?)ViewData[PageContentElements.MetaTitle];

	var pageContentData = (Dictionary<string, MixedContentPageItem?>?)ViewData[PageContentElements.PageContent];
	var pageContent = pageContentData != null
		? pageContentData
		: new Dictionary<string, MixedContentPageItem?>();

	var headline = pageContent.GetValueOrDefault("MemberManagement.AddMember.ProfileDisabled.Title", null);
	var body = pageContent.GetValueOrDefault("MemberManagement.AddMember.ProfileDisabled.Body", null);
	var searchLabel = pageContent.GetValueOrDefault("MemberManagement.AddMember.ProfileDisabled.ButtonLabel", null);
}

@section BackNavigation {
	<partial name="_BackNavigation" model="@("mm:searchRecMember", "Back", new Dictionary<string, string> { { "RecId", Model } })" />
}

<div class="govuk-grid-row">
	<div class="govuk-grid-column-two-thirds">
		<h1 class="govuk-heading-l">@Html.Raw(headline?.Value)</h1>
		<div>
			@Html.Raw(body?.Value)
		</div>
		<a href="#" class="govuk-button">@Html.Raw(searchLabel?.Value)</a>
	</div>
</div>
