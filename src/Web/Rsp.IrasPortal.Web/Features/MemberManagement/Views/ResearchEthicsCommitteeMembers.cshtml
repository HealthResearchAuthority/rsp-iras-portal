@using Rsp.IrasPortal.Web.Features.MemberManagement.Models
@using Rsp.Portal.Application.Constants
@using Rsp.Portal.Application.DTOs
@using Rsp.Portal.Application.DTOs.Responses.CmsContent
@model RecMembersViewModel

@{
	var pageContentData = (Dictionary<string, MixedContentPageItem?>?)ViewData[PageContentElements.PageContent];
	var pageContent = pageContentData != null
		? pageContentData
		: new Dictionary<string, MixedContentPageItem?>();

	var headline = pageContent.GetValueOrDefault("MemberManagement.ResearchEthicsCommitteesProfile.Title", null);

	ViewData["Title"] = $"Members of {Model.RecName}";
	ViewData["Subtitle"] = "Add a member to this research ethics committee";
	ViewData["Hint"] = "Search for a member and assign them to this committee. \nTo change the committee a member is assigned to, go to the member’s profile instead.";

	ViewBag.Style = "govuk-button govuk-button--secondary";

	var tableId = "recMembersTable";

	var sortableHeaders = new[]
	{
		new { Field = nameof(RecMemberViewModel.FirstName), Label = "First name" },
		new { Field = nameof(RecMemberViewModel.LastName), Label = "Last name" },
		new { Field = nameof(RecMemberViewModel.EmailAddress), Label = "Email address" },
		new { Field = nameof(RecMemberViewModel.CommitteeRole), Label = "Committee role" },
		new { Field = nameof(RecMemberViewModel.Designation), Label = "Designation" },
	};
	var showSuccessMessage = TempData[TempDataKeys.ShowNotificationBanner];
}

@section Breadcrumb {
	@await Html.PartialAsync("_Breadcrumb", new List<(string, string?)>
	{
		("Member management", Url.RouteUrl("mm:home")),
		("Research ethics committees", Url.RouteUrl("mm:researchethicscommittees")),
		($"Research ethics committee profile: {Model.RecName}", Url.RouteUrl("mm:researchethicscommitteesprofile", new {id = Model.RecId}))}
					)
}

@if (showSuccessMessage is true)
{
	<div class="govuk-grid-row">
		<div class="govuk-grid-column-two-thirds">
			<partial name="_NotificationBanner"
					 model="@(new NotificationBannerModel
                        {
                            Title = "Success",
                            Heading = "New member added to the research ethics committee"
                        })" />
		</div>
	</div>
}

<div class="govuk-grid-row">

	<div class="govuk-grid-column-one-half">
		<h1 class="govuk-heading-l">@ViewData["Title"]</h1>
	</div>

</div>

<div class="govuk-grid-row  govuk-!-margin-top-3">

	<div class="govuk-grid-column-full">
		<div class="govuk-label"><b>@ViewData["Subtitle"]</b></div>
	</div>
	<div class="govuk-grid-column-two-thirds govuk-!-margin-bottom-2">
		<div class="govuk-label">@ViewData["Hint"]</div>
	</div>
	<div class="govuk-grid-column-two-thirds govuk-!-margin-bottom-4">
		<a class="govuk-button" asp-route="mm:searchrecmember" asp-route-recId="@Model.RecId"> Add a member </a>
	</div>

</div>

<div class="govuk-grid-row">

	<div class="govuk-grid-column-full">
		@if (Model.RecUsers != null && Model.RecUsers.Any())
		{
			<div class="govuk-table-wrapper">
				<table class="govuk-table govuk-table-users" id="@tableId">
					<thead>
						<tr class="govuk-table__row govuk-table__header-sortable govuk-body-s">
							@foreach (var header in sortableHeaders)
							{
								var sortableHeaderModel = new SortableHeaderModel
					{
						FieldName = header.Field,
						DisplayText = header.Label,
						CurrentSortField = Model.Pagination?.SortField,
						CurrentSortDirection = Model.Pagination?.SortDirection,
						TableId = tableId,
						AdditionalParameters = new Dictionary<string, string> { ["id"] = Model.RecId.ToString() ?? Guid.Empty.ToString() }
					};

								<th scope="col" class="govuk-table__header govuk-table__header-sortable">
									<partial name="_SortableHeaderButton" model="@sortableHeaderModel" />
								</th>
							}
							<th scope="col" class="govuk-table__header">Action</th>
						</tr>
					</thead>
					<tbody class="govuk-table__body">
						@foreach (var recMember in Model.RecUsers)
						{
							<tr class="govuk-table__row">
								<td class="govuk-table__cell">@recMember.FirstName</td>
								<td class="govuk-table__cell">@recMember.LastName</td>
								<td class="govuk-table__cell">@recMember.EmailAddress</td>
								<td class="govuk-table__cell">@recMember.CommitteeRole</td>
								<td class="govuk-table__cell">@recMember.Designation</td>
								<td class="govuk-table__cell">
									<a class="govuk-link" asp-route="mm:checkrecmember" asp-route-recId="@Model.RecId" asp-route-userId="@recMember.UserId">
										View/Edit
									</a>
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		}

		else if ((Model.RecUsers is null || !Model.RecUsers.Any()))
		{
			<div class="govuk-grid-column-two-thirds search-filter-error-border">
				<h2 class="govuk-heading-l">There are no members</h2>
			</div>
		}

	</div>
</div>