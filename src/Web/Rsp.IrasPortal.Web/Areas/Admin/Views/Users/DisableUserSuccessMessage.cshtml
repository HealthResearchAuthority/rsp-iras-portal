@using Rsp.Portal.Web.Areas.Admin.Models
@model UserViewModel
@{
	ViewBag.Active = "manageUsers";
	ViewBag.Title = "User disabled - Manage Users - System Administration";
}
<div class="govuk-grid-row">
	<div class="govuk-grid-column-two-thirds">
		<div class="govuk-panel govuk-panel--confirmation">
			<h1 class="govuk-panel__title">
				The user account for @Model.GivenName @Model.FamilyName has been disabled
			</h1>
		</div>
		<p class="govuk-body">
			This can be enabled again if needed from the Manage users section.
		</p>
		<p class="govuk-body">
			<a class="govuk-link" asp-route="admin:users">Back to Manage users</a>
		</p>
	</div>
</div>
