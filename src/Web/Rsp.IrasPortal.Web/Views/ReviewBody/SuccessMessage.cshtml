@{
	var heading = "";
	var messageText = "";

	switch (ViewBag.Mode)
	{
		case "create":
			{
				heading = "Review body has been added";
				messageText = $"{Model.RegulatoryBodyName} has now been created as a review body. Their status is now active.";
				ViewData["Title"] = "Review body added- Manage review bodies - System Administration";
			}
			break;
		case "disable":
			{
				heading = "Review body disabled";
				messageText = $"{Model.RegulatoryBodyName} has now been disabled as a review body. This can be enabled again if needed from the Manage review bodies section.";
				ViewData["Title"] = "Review body disabled - Manage review bodies - System Administration";
			}
			break;
		case "enable":
			{
				heading = "Review body enabled";
				messageText = $"{Model.RegulatoryBodyName} has now been enabled as a review body. This can be disabled again if needed from the Manage review bodies section.";
				ViewData["Title"] = "Review body enabled - Manage review bodies - System Administration";
			}
			break;
	}
}

@model AddUpdateReviewBodyModel

<div class="govuk-grid-row">
	<div class="govuk-grid-column-two-thirds">
		<div class="govuk-panel govuk-panel--confirmation">
			<h1 class="govuk-panel__title">
				@heading
			</h1>
		</div>

		<p class="govuk-body">
			@messageText
		</p>

		@if (ViewBag.Mode == "create")
		{
			<p class="govuk-body">
				<a class="govuk-link" asp-action="CreateReviewBody">Add another review body</a>
			</p>
		}

		<p class="govuk-body">
			<a class="govuk-link" asp-route="rbc:viewreviewbodies">Back to Manage review bodies</a>
		</p>
	</div>
</div>