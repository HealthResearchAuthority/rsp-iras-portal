@using Rsp.IrasPortal.Application.DTOs.Responses
@using Rsp.IrasPortal.Web.Features.ProjectCollaborators.Models
@using Rsp.IrasPortal.Web.Models
@using Rsp.Portal.Application.Constants;
@using Rsp.Portal.Application.Extensions
@using Rsp.Portal.Domain.AccessControl
@using Rsp.Portal.Web.Models
@using System.Text.Json
@model ProjectTeamViewModel

@{
    ViewBag.Title = "Project overview";
    ViewBag.Active = ProjectOverview.ProjectTeam;
}

@{
    var routeName = (ViewData["BackRoute"] as string) ?? "app:Welcome";
    var routeValues = ViewData["BackRouteValues"] as Dictionary<string, string>
                      ?? new Dictionary<string, string>();
    var projectTitle = !string.IsNullOrEmpty(Model.ProjectOverviewModel.ProjectTitle) ? Model.ProjectOverviewModel.ProjectTitle : "Project overview";

    var tdBackRouteValues = TempData.Peek(TempDataKeys.ProjectOverviewReferrer.BackRouteValues);
    TempData[TempDataKeys.ProjectModification.LinkBackToReferrer] = true;

    var backRouteValues = JsonSerializer.Deserialize<Dictionary<string, string>>
        (tdBackRouteValues != null ? tdBackRouteValues.ToString()! : "{}") ?? new Dictionary<string, string>();

}

@if (routeName is null || routeName.ToLower() == "app:welcome")
{
    @section Breadcrumb {
        @await Html.PartialAsync("_Breadcrumb", new List<(string, string?)>
        {
            ("My research",Url.RouteUrl("app:welcome")),
            (projectTitle, Url.RouteUrl("pov:projectdetails", new Dictionary<string, string>{{"projectRecordId", Model.ProjectOverviewModel.ProjectRecordId!}}))
        })
    }
}
else
{
    @section BackNavigation {
        <partial name="_BackNavigation" model="@(routeName, "Back", backRouteValues)" />
    }
}

@{
    var operationMessage = TempData[TempDataKeys.ProjectCollaborators.OperationMessage] as string;

    if (operationMessage != null)
    {
        var notificationModel = new NotificationBannerModel
        {
            Title = "Success",
            Heading = operationMessage
        };

        <partial name="_NotificationBanner" model="notificationModel" />
    }
}

<partial name="_NavigationHeaderPartial" model="@Model.ProjectOverviewModel" />

<div class="govuk-grid-row">
    <div class="govuk-width-container govuk-!-margin-top-4">
        @foreach (var group in Model.ProjectOverviewModel.SectionGroupQuestions)
        {
            <h2 class="govuk-heading-m">@group.SectionGroup</h2>
            <dl class="govuk-summary-list">
                @foreach (var question in group.Questions)
                {
                    string questionText = string.IsNullOrWhiteSpace(question.ShortQuestionText) ? question.QuestionText : question.ShortQuestionText;

                    <div class="govuk-summary-list__row">
                        <dt class="govuk-summary-list__key">@questionText</dt>
                        <dd class="govuk-summary-list__value">
                            @Html.Raw(question.GetDisplayText(includePrompt: false))
                        </dd>
                    </div>
                }
            </dl>
        }
    </div>
</div>

<feature name="@FeatureFlags.TeamRoles">
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
            <h2 class="govuk-heading-m">Collaborators</h2>
            <p class="govuk-body">If other members of the project team will need to view and manage the project's records in this service, you can add them as a collaborator.</p>
            <p class="govuk-body">A project must always have at least one collaborator with edit access. If you need to remove the only collaborator with edit access, add another collaborator with edit access to replace them first.</p>
        </div>
    </div>
    <div class="govuk-grid-row">
        <div class="govuk-width-container">
            @{
                var tableId = "collaboratorTable";
                var sortableHeaders = new[]
                {
                    new { Field = nameof(CollaboratorViewModel.Email), Label = "Collaborator email" },
                    new { Field = nameof(CollaboratorViewModel.ProjectAccessLevel), Label = "Project access" }
                };
            }

            <table class="govuk-table govuk-table-users" id="@tableId">
                <thead>
                    <tr class="govuk-table__row govuk-table__header-sortable govuk-body-s">
                        @foreach (var header in sortableHeaders)
                        {
                            var sortableHeaderModel = new SortableHeaderModel
                            {
                                FieldName = header.Field,
                                DisplayText = header.Label,
                                CurrentSortField = Model.Pagination?.SortField,
                                CurrentSortDirection = Model.Pagination?.SortDirection,
                                AdditionalParameters = Model.Pagination?.AdditionalParameters ?? new Dictionary<string, string>() { },
                                TableId = tableId,
                            };

                            <th scope="col" class="govuk-table__header govuk-table__header-sortable">
                                <partial name="_SortableHeaderButton" model="@sortableHeaderModel" />
                            </th>
                        }
                        <th scope="col" class="govuk-table__header">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var projects = Context.Items[ContextItemKeys.CollaboratorProjects] as string;

                        var collaboratorProjects = string.IsNullOrWhiteSpace(projects) ?
                            new List<CollaboratorProjectResponse>() :
                            JsonSerializer.Deserialize<List<CollaboratorProjectResponse>>(projects) ??
                            [];

                        var userIsCollaboratorWithEditAccess = User.IsCollaboratorWithEditAccess
                        (
                            collaboratorProjects,
                            Model.ProjectOverviewModel.ProjectRecordId!
                        );

                        var totalCollaborators = Model.Collaborators.Count;
                        var totalCollaboratorsWithEditAccess = Model.Collaborators.Count(c => c.ProjectAccessLevel == "Edit");
                    }

                    @foreach (var collaborator in Model.Collaborators)
                    {
                        <tr class="govuk-table__row">
                            <td class="govuk-table__cell">@collaborator.Email</td>
                            <td class="govuk-table__cell">@collaborator.ProjectAccessLevel</td>
                            <td class="govuk-table__cell">

                                <ul class="govuk-summary-card__actions">
                                    <!--If there is only one collaborator, no actions are available-->
                                    @if (totalCollaborators == 1)
                                    {
                                        <li class="govuk-summary-card__action">
                                            Not available
                                        </li>
                                    }
                                    else
                                    {
                                        var routeParams = new Dictionary<string, string>
                                        {
                                            { "id", collaborator.Id!.ToString() },
                                            { "projectAccessLevel", collaborator.ProjectAccessLevel! },
                                            { "email", collaborator.Email! },
                                            { "userId", collaborator.UserId! },
                                            { "projectRecordId", Model.ProjectOverviewModel.ProjectRecordId! },
                                            { "self", collaborator.Self.ToString() }
                                        };

                                        var (showChangeLink, showRemoveLink) = userIsCollaboratorWithEditAccess switch
                                        {
                                            // current and other users with edit access
                                            true when totalCollaboratorsWithEditAccess > 1 => (collaborator.Self, collaborator.IsOwner) switch
                                            {
                                                (true, true) => (false, false),  // user is current and owner, don't allow links
                                                (true, false) => (true, true),   // user is current but not owner, allow change / remove
                                                (false, true) => (false, false), // user is not current but is owner, don't allow links
                                                (false, false) => (true, true)   // user is not current and not owner, allow links
                                            },
                                            
                                            // current user is only one with edit access
                                            true when totalCollaboratorsWithEditAccess == 1 => (collaborator.Self, collaborator.IsOwner) switch // 
                                            {
                                                (true, true) => (false, false),  // user is current and owner, don't allow links
                                                (true, false) => (false, false), // user is current but not owner, don't allow links
                                                (false, true) => (false, false), // user is not current but is owner, don't allow links
                                                (false, false) => (true, true)   // user is not current and not owner, allow links
                                            },
                                            // user doesn't have edit access
                                            _ => (collaborator.Self, collaborator.IsOwner) switch
                                            {
                                                (true, true) => (false, false),  // user is current and owner, don't allow links
                                                (true, false) => (false, true),  // user is current but not owner, allow remove
                                                (false, true) => (false, false), // user is not current but is owner, don't allow links
                                                (false, false) => (false, false) // user is not current and not owner, don't allow links
                                            }
                                        };


                                        if (showChangeLink)
                                        {
                                            <li class="govuk-summary-card__action">
                                                <a asp-route="col:selectcollaboratoraccess"
                                                asp-all-route-data="@routeParams"
                                                class="govuk-link" aria-label="Change access">
                                                    Change access
                                                </a>
                                            </li>
                                        }

                                        if (showRemoveLink)
                                        {
                                            <li class="govuk-summary-card__action">
                                                <a asp-route="col:removecollaborator"
                                                asp-all-route-data="@routeParams"
                                                class="govuk-link" aria-label="Remove collaborator">
                                                    Remove
                                                </a>
                                            </li>
                                        }

                                        if (!showChangeLink && !showRemoveLink)
                                        {
                                            <li class="govuk-summary-card__action">
                                                Not available
                                            </li>
                                        }
                                    }
                                </ul>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <a asp-route="col:addcollaborator"
           asp-route-projectRecordId="@Model.ProjectOverviewModel.ProjectRecordId"
           class="govuk-button govuk-button--secondary"
           permission="@Permissions.MyResearch.ProjectRecord_Update">
        Add collaborator
    </a>
</feature>